# ============================================
# PLANTILLA - Copia como .env y completa
# ============================================

# Base de datos MySQL
DB_HOST=tu_host_mysql
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_NAME=tu_base_de_datos

# Clave secreta de Flask (genera una con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=genera_una_clave_aleatoria

# Correo (Gmail - usar contraseña de aplicación, NO la contraseña normal)
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_contraseña_de_aplicacion
